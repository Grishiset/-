import Data.List (foldl')

-- Сумма 1^2 + 2^2 + ... + n^2 (mod modulo)
-- В Haskell Integer произвольной точности — __int128 не нужен
pyramidal :: Integer -> Integer -> Integer
pyramidal n modulo =
  (n * (n + 1) * (2 * n + 1) `div` 6) `mod` modulo

-- Целочисленный квадратный корень
isqrt :: Integer -> Integer
isqrt = floor . (sqrt :: Double -> Double) . fromIntegral

solve :: Integer -> Integer -> Integer
solve n modulo = (sum1 + sum2) `mod` modulo
  where
    threshold = isqrt n

    -- Малые делители: i от 1 до sqrt(n)
    sum1 = foldl' step 0 [1..threshold]
      where
        step acc i =
          let cnt = (n `div` i) `mod` modulo
              sq  = (i * i)     `mod` modulo
          in (acc + cnt * sq) `mod` modulo

    -- Крупные делители: группируем по одинаковому значению n/i
    sum2 = foldl' step 0 [1..(n `div` (threshold + 1))]
      where
        step acc j =
          let from  = n `div` j
              to    = n `div` (j + 1)
              pFrom = pyramidal from modulo
              pTo   = pyramidal to   modulo
              -- +modulo чтобы не уйти в отрицательные
              diff  = if pFrom < pTo
                        then pFrom + modulo - pTo
                        else pFrom - pTo
          in (acc + j * diff `mod` modulo) `mod` modulo

main :: IO ()
main = do
  let modulo = 1000000000          -- 10^9
  let defaultN = 1000000000000000  -- 10^15
  line <- getLine
  let n = if null line then defaultN else read line
  print (solve n modulo)
